# FamilyQuest API integration test environment.
# Used by npm run test:api. Copy to .env.test only if you need to override defaults.
#
# The default test runner opens an SSH tunnel:
# local 127.0.0.1:15432 -> Proxmox -> CT 102 PostgreSQL.
# This database is separate from production.

DATABASE_URL="postgresql://familyquest_test:familyquest_test_password@127.0.0.1:15432/familyquest_test?schema=public"
JWT_SECRET="test-secret-change-only-if-needed-32chars"
JWT_EXPIRES_IN="7d"
CHILD_CODE_PEPPER="test-child-code-pepper-change-only-if-needed-32chars"
CHILD_JWT_EXPIRES_IN="24h"
BCRYPT_ROUNDS=4
NODE_ENV=test
PORT=3011
CORS_ORIGINS="http://127.0.0.1:3011,http://localhost:3011"
RATE_LIMIT_MAX_REQUESTS=0
AUTH_RATE_LIMIT_MAX_REQUESTS=100
CHILD_LOGIN_FAILED_MAX_ATTEMPTS=100
CHILD_LOGIN_CODE_FAILED_MAX_ATTEMPTS=8
ALLOW_DEBUG_RESET_TOKEN=true
ALLOW_PUBLIC_REGISTRATION=true
