{
  "name": "familyquest-backend",
  "version": "1.0.0",
  "description": "FamilyQuest - Backend API for family task management",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "prisma db push && node server.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "postinstall": "prisma generate",
    "db:studio": "prisma studio",
    "frontend:dev": "vite",
    "frontend:build": "vite build",
    "frontend:preview": "vite preview",
    "test": "jest --coverage --runInBand",
    "test:db:setup": "node scripts/setup-test-db.js",
    "test:api": "node scripts/run-api-tests.js",
    "test:smoke": "node scripts/smoke-e2e.js",
    "test:ranking": "node scripts/check-ranking-order.js",
    "test:reverse-approval": "node scripts/check-reverse-approval.js",
    "test:restore-backup": "node scripts/check-restore-backup.js",
    "test:state-version": "node scripts/check-family-state-versioning.js",
    "test:bulk-approve": "node scripts/check-bulk-approve-filter.js",
    "test:point-ledger": "node scripts/check-point-ledger-history.js",
    "test:task-archive": "node scripts/check-task-archive-matching.js",
    "test:task-restore": "node scripts/check-task-restore-archive.js",
    "test:extra-task-resubmit": "node scripts/check-extra-task-resubmit.js",
    "test:task-edit": "node scripts/check-task-edit-modal.js",
    "test:frontend-source": "node scripts/check-frontend-source.js",
    "test:child-actions": "node scripts/check-child-actions-layout.js",
    "test:mobile-layout": "node scripts/check-mobile-layout.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "family",
    "tasks",
    "gamification",
    "streaks",
    "rewards",
    "parental-control"
  ],
  "author": "FamilyQuest Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^5.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "vite": "^8.0.13"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/michalreczek1/FamilyQest3.git"
  },
  "bugs": {
    "url": "https://github.com/michalreczek1/FamilyQest3/issues"
  },
  "homepage": "https://github.com/michalreczek1/FamilyQest3#readme"
}
