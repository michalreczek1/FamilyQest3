# FamilyQuest environment template
# Copy to .env only on the machine that runs the app.
# Production secrets live on Proxmox CT 103 in /opt/familyquest/.env.

# PostgreSQL in the current Proxmox deployment is CT 102 (192.168.33.121).
# Do not use old Railway DATABASE_URL values here.
DATABASE_URL="postgresql://familyquest:<password>@192.168.33.121:5432/familyquest?schema=public"

JWT_SECRET="replace-with-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"
CHILD_CODE_PEPPER="replace-with-random-child-code-pepper-min-32-chars"
CHILD_JWT_EXPIRES_IN="24h"
BCRYPT_ROUNDS=12

NODE_ENV=production
PORT=3000
CORS_ORIGINS="https://fq.familyos.pl"

# 0 disables global API rate limiting. Login guards below still apply.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=0
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
CHILD_LOGIN_FAILED_WINDOW_MS=900000
CHILD_LOGIN_FAILED_MAX_ATTEMPTS=40
CHILD_LOGIN_CODE_FAILED_MAX_ATTEMPTS=8

# Development/test only. Keep false in production unless debugging deliberately.
ALLOW_DEBUG_RESET_TOKEN=false
ALLOW_PUBLIC_REGISTRATION=false
